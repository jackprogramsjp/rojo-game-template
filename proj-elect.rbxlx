      <Item class="ModuleScript" referent="105">
        <Properties>
          <string name="Name">test</string>
          <string name="Source"><![CDATA[type Config = {
	colors: boolean?,
	verbose: boolean?,
}

type Scope = {
	status: number,
	name: string,
	only: boolean?,
	skip: boolean?,
	parent: Scope?,
	children: { Scope | Test },
	passes: number,
	fails: number,
	skips: number,
	runtime: number,
	afterEach: () -> (),
	beforeEach: () -> (),
}

type Test = {
	status: number,
	name: string,
	only: boolean?,
	skip: boolean?,
	parent: Scope,
	children: nil,
	run: () -> (),
	result: unknown?,
	line: number?,
	runtime: number,
}

local options = {
	colors = game :: any == nil,
	verbose = game :: any ~= nil,
}

local color = {
	white = function(text: string)
		return if options.colors then `\27[37;1m{text}\27[0m` else text
	end,
	gray = function(text: string)
		return if options.colors then `\27[90;1m{text}\27[0m` else text
	end,
	green = function(text: string)
		return if options.colors then `\27[32;1m{text}\27[0m` else `\u{1F7E2} {text}`
	end,
	red = function(text: string)
		return if options.colors then `\27[31;1m{text}\27[0m` else `\u{1F534} {text}`
	end,
	blue = function(text: string)
		return if options.colors then `\27[34;1m{text}\27[0m` else `\u{1F535} {text}`
	end,
}

local PENDING = 0
local PASS = 1
local FAIL = 2
local SKIP = 3
local ERROR = 4

local tests: { Test } = {}
local scopes: { Scope } = {}
local rootScope: Scope = {
	status = PENDING,
	name = "root",
	children = {},
	passes = 0,
	fails = 0,
	skips = 0,
	runtime = 0,
	afterEach = function() end,
	beforeEach = function() end,
}
local activeScope = rootScope

local function describe(name: string, run: () -> ()): Scope
	local this: Scope = {
		status = PENDING,
		name = name,
		parent = activeScope,
		children = {},
		passes = 0,
		fails = 0,
		skips = 0,
		runtime = 0,
		afterEach = activeScope.afterEach,
		beforeEach = activeScope.beforeEach,
	}

	local prevScope = activeScope
	activeScope = this
	run()
	activeScope = prevScope

	table.insert(activeScope.children, this)
	table.insert(scopes, this)

	return this
end

local function test(name: string, run: () -> ()): Test
	local this: Test = {
		status = PENDING,
		name = name,
		parent = activeScope,
		run = run,
		runtime = 0,
	}

	table.insert(activeScope.children, this)
	table.insert(tests, this)

	return this
end

local function skip()
	activeScope.skip = true
end

local function only()
	activeScope.only = true
	rootScope.only = true
end

local function testSkip(name: string, run: () -> ()): Test
	local this = test(name, run)
	this.skip = true
	return this
end

local function testOnly(name: string, run: () -> ()): Test
	local this = test(name, run)
	this.only = true
	rootScope.only = true
	return this
end

local function describeSkip(name: string, run: () -> ()): Scope
	local this = describe(name, run)
	this.skip = true
	return this
end

local function describeOnly(name: string, run: () -> ()): Scope
	local this = describe(name, run)
	this.only = true
	rootScope.only = true
	return this
end

local function describeIf(predicate: () -> boolean): typeof(describe)
	if predicate() then
		return describe
	end
	return function(name: string)
		return describeSkip(name, function() end)
	end
end

local function afterEach(callback: () -> ())
	local lastCallback = activeScope.afterEach
	function activeScope.afterEach()
		lastCallback()
		callback()
	end
end

local function beforeEach(callback: () -> ())
	local lastCallback = activeScope.beforeEach
	function activeScope.beforeEach()
		lastCallback()
		callback()
	end
end

local function isOnly(test: Test): boolean
	if not rootScope.only or test.only then
		return true
	end

	local parent: Scope? = test.parent
	while parent and parent ~= rootScope do
		if parent.only then
			return true
		elseif parent.skip then
			return false
		end
		parent = parent.parent
	end

	return false
end

local function isSkip(test: Test): boolean
	if test.only then
		return false
	elseif test.skip then
		return true
	end

	local parent: Scope? = test.parent
	while parent do
		if parent.only and parent ~= rootScope then
			return false
		elseif parent.skip then
			return true
		end
		parent = parent.parent
	end

	return false
end

local function runTests()
	for _, test in tests do
		if isSkip(test) or not isOnly(test) then
			test.status = SKIP
			continue
		end

		test.parent.beforeEach()

		local start = os.clock()
		local success = xpcall(test.run, function(result)
			test.status = FAIL
			test.result = debug.traceback(tostring(result), 2)
			test.line = debug.info(2, "l")
			if test.line == -1 then
				test.line = debug.info(3, "l")
			end
		end)

		test.runtime = os.clock() - start

		if success then
			test.status = PASS
		end

		test.parent.afterEach()
	end
end

local function updateScope(scope: Scope)
	if not scope.children[1] then
		scope.status = if scope.skip then SKIP else PASS
		return
	end

	scope.status = SKIP

	for _, child in scope.children do
		if child.children then
			updateScope(child)
			scope.passes += child.passes
			scope.fails += child.fails
		elseif child.status == PASS then
			scope.passes += 1
		elseif child.status == FAIL then
			scope.fails += 1
		end

		-- Only count skips in direct children
		if child.status == SKIP then
			scope.skips += 1
		end

		scope.runtime += child.runtime

		if child.status == FAIL then
			scope.status = FAIL
		elseif scope.status == SKIP and child.status == PASS then
			scope.status = PASS
		end
	end
end

local function getIndent(node: Scope | Test): string
	local depth = 0
	local parent = node.parent
	while parent and parent ~= rootScope do
		depth += 1
		parent = parent.parent
	end
	return if depth > 0 then string.rep("  ", depth - 1) .. color.gray("· ") else ""
end

local function getPath(node: Scope | Test): string
	local path = { "" }
	local parent = node.parent
	while parent and parent ~= rootScope do
		table.insert(path, 1, parent.name)
		parent = parent.parent
	end
	return table.concat(path, " > ")
end

local function greenOrRed(text: string, good: boolean): string
	return if good then color.green(text) else color.red(text)
end

local function colorStatus(status: number): string
	local wall = color.gray("│")

	if status == PASS then
		return color.green("PASS") .. wall
	elseif status == FAIL then
		return color.red("FAIL") .. wall
	elseif status == SKIP then
		return color.blue("SKIP") .. wall
	else
		return color.red("ERROR") .. wall
	end
end

local function report()
	local output = {}

	local function reportScope(scope: Scope)
		local name = color.white(scope.name)
		local text = `{colorStatus(scope.status)} {getIndent(scope)}{name}`

		if scope.fails > 0 then
			text ..= " " .. color.red(`({scope.fails})`)
		end

		if scope.skips > 0 then
			text ..= " " .. color.blue(`({scope.skips} skipped)`)
		elseif scope.fails == 0 then
			text ..= " " .. color.gray(string.format("%.2fms", scope.runtime * 1000))
		end

		table.insert(output, text)
	end

	local function reportTest(test: Test, reportError: boolean?)
		if test.status ~= FAIL and not options.verbose then
			return
		end

		local line = color.red(`{test.line}:`)

		if reportError then
			local name = color.white(test.name)
			local path = color.gray(getPath(test))

			table.insert(output, `{colorStatus(ERROR)} {path}{line}{name}`)
			table.insert(output, `{test.result}`)
		else
			local name = color.gray(test.name)
			local indent = getIndent(test)

			if test.status == FAIL then
				table.insert(output, `{colorStatus(FAIL)} {indent}{line}{name}`)
			else
				table.insert(output, `{colorStatus(test.status)} {indent}{name}`)
			end
		end
	end

	local function reportNode(node: Scope | Test)
		if not node.children then
			return reportTest(node :: Test)
		end

		reportScope(node)

		for _, child in node.children do
			reportNode(child)
		end
	end

	local function reportSummary()
		local scopePassCount = 0
		local scopeFailCount = 0

		for _, scope in scopes do
			if scope.status == PASS then
				scopePassCount += 1
			elseif scope.status == FAIL then
				scopeFailCount += 1
			end
		end

		local describeText = `{greenOrRed(`{scopePassCount} passed`, scopeFailCount == 0)} {color.gray(`({#scopes})`)}`
		local testText = `{greenOrRed(`{rootScope.passes} passed`, rootScope.fails == 0)} {color.gray(`({#tests})`)}`
		local duration = `{color.blue(`{string.format("%.2fms", rootScope.runtime * 1000)}`)}`

		table.insert(output, "")
		table.insert(output, `Describe  {describeText}`)
		table.insert(output, `   Tests  {testText}`)
		table.insert(output, `Duration  {duration}`)
		table.insert(output, "")
	end

	local function reportErrors()
		if rootScope.fails == 0 then
			return
		end

		for _, test in tests do
			if test.status == FAIL then
				reportTest(test, true)
				table.insert(output, "")
			end
		end
	end

	table.insert(output, "")
	table.insert(output, color.blue("Test Results"))
	table.insert(output, "")

	for _, child in rootScope.children do
		reportNode(child)
	end

	reportSummary()
	reportErrors()

	print(table.concat(output, "\n"))

	if rootScope.fails > 0 then
		error(color.red(`{rootScope.fails} test(s) failed`))
	end
end

local function finish(config: Config?)
	if config then
		options.colors = if config.colors ~= nil then config.colors else options.colors
		options.verbose = if config.verbose ~= nil then config.verbose else options.verbose
	end

	runTests()
	updateScope(rootScope)
	report()
end

return setmetatable({
	test = test,
	testSkip = testSkip,
	testOnly = testOnly,
	skip = testSkip,
	only = testOnly,
	describe = describe,
	describeSkip = describeSkip,
	describeOnly = describeOnly,
	describeIf = describeIf,
	skipAll = skip,
	onlyAll = only,
	afterEach = afterEach,
	beforeEach = beforeEach,
	finish = finish,
}, {
	__call = function(_, name: string, run: () -> ())
		return test(name, run)
	end,
})
]]></string>
